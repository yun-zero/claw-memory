{
  "name": "@yun-zero/claw-memory",
  "version": "0.5.0",
  "description": "OpenClaw 记忆插件 - 自动保存对话，智能注入上下文",
  "main": "dist/plugin.js",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e",
    "test:stress": "vitest run test/stress",
    "test:all": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "node-cron": "^4.2.1",
    "openclaw": "^2026.3.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai",
    "plugin"
  ]
}

{
  "id": "claw-memory",
  "name": "ClawMemory",
  "version": "0.2.4",
  "description": "AI memory system - auto-save conversations and inject memory summary",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "autoSave": {
        "type": "boolean"
      },
      "dataDir": {
        "type": "string"
      },
      "maxContextMemories": {
        "type": "number"
      },
      "enableVector": {
        "type": "boolean"
      },
      "llm": {
        "type": "object",
        "properties": {
          "baseUrl": { "type": "string" },
          "apiKey": { "type": "string" },
          "model": { "type": "string" }
        }
      }
    }
  }
}
